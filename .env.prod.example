# Core database settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=ecommerce

# Optional service connectivity overrides
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
KAFKA_BROKER=kafka:29092
MEILI_MASTER_KEY=replace-with-strong-meili-key
MEILI_PUBLIC_PORT=17700
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
MINIO_API_PUBLIC_PORT=19000
MINIO_CONSOLE_PUBLIC_PORT=19001

# Public HTTP entrypoint
BFF_PUBLIC_PORT=3000
FE_PUBLIC_PORT=3700
ADMIN_FE_PUBLIC_PORT=3800
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3000/graphql
ADMIN_NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3000/graphql
CORS_ORIGINS=http://localhost:3700,http://localhost:3800
GRAPHQL_INTROSPECTION=true
GRAPHQL_PLAYGROUND=true

# Docker Hub images (published by CI/CD)
AUTH_IMAGE=docker.io/phongdosw/auth-service:latest
PAYMENT_IMAGE=docker.io/phongdosw/payment-service:latest
ORDER_IMAGE=docker.io/phongdosw/order-service:latest
PRODUCT_IMAGE=docker.io/phongdosw/product-service:latest
BFF_IMAGE=docker.io/phongdosw/bff-gateway:latest
FE_IMAGE=docker.io/phongdosw/e-commerce-fe:latest
ADMIN_FE_IMAGE=docker.io/phongdosw/e-commerce-admin-fe:latest
