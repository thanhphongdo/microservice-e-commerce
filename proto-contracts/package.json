{
  "name": "@ecommerce/proto-contracts",
  "version": "1.0.0",
  "private": true,
  "description": "Shared gRPC proto contracts for microservice-e-commerce",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "proto/**/*.proto"
  ],
  "scripts": {
    "generate": "mkdir -p ./src/generated && protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./src/generated --ts_proto_opt=nestJs=true,outputServices=grpc-js,esModuleInterop=true,outputClientImpl=false,outputEncodeMethods=false,outputJsonMethods=false,outputPartialMethods=false,useDate=string,snakeToCamel=true -I ./proto ./proto/*.proto",
    "build": "npm run generate && tsc -p tsconfig.json",
    "lint": "echo \"No lint for proto contracts\""
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.0",
    "@nestjs/microservices": "^11.1.6",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "protoc": "^33.0.0",
    "ts-proto": "^2.8.1",
    "typescript": "^5.9.2"
  }
}
